{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"]
    },
    "@fit-analyzer/server#build": {
      "dependsOn": ["@fit-analyzer/web#build", "^build"],
      "outputs": ["dist/**", "public/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    }
  }
}
