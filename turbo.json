{
	"$schema": "https://turbo.build/schema.json",
	"tasks": {
		"build": {
			"dependsOn": ["^build"],
			"env": ["GIT_COMMIT"],
			"outputs": ["dist/**"]
		},
		"@fit-analyzer/server#build": {
			"dependsOn": ["@fit-analyzer/web#build", "^build"],
			"outputs": ["dist/**", "public/**"]
		},
		"dev": {
			"cache": false,
			"persistent": true
		},
		"typecheck": {
			"dependsOn": ["^typecheck"],
			"outputs": []
		}
	}
}
